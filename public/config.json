  "CONSTELLATION": {
    "displayDuration": 5000
  },

  "END": {
    "displayDuration": 5000
  },

  "PRINTER": {
    "dots": 576,
    "darknessThreshold": 200
  },

  "CREDITS": {
    "displayDuration": 5000
  },

  "API": {
    "mock": false,
    "baseUrl": "http://localhost:8000",
    "endpoints": {
      "assets": "/assets",
      "ping": "/api",
      "transcript": "/api/transcript",
      "questions": "/api/questions",
      "artworks": "/api/artworks",
      "testimonies": "/api/testimonies",
      "testimoniesAll": "/api/testimonies/all",
      "testimony": "/api/testimony",
      "print": "/api/print_png",
